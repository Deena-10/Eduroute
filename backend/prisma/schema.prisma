// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               Int       @id @default(autoincrement())
  uid              String?   @unique @db.VarChar(100)
  firebase_uid     String?   @unique
  name             String    @db.VarChar(100)
  email            String    @unique @db.VarChar(255)
  password         String?   @db.VarChar(255)
  profile_picture  String?   @db.VarChar(255)
  created_at       DateTime  @default(now())
  
  profile          Profile?
  roadmaps         Roadmap[]
  chat_history     ChatHistory[]
  streak           Streak?
  notifications    Notification[]

  @@map("users")
}

model Profile {
  id                Int      @id @default(autoincrement())
  user_id           Int      @unique
  education_grade   String?  @db.VarChar(100)
  education_department String? @db.VarChar(100)
  education_year    String?  @db.VarChar(50)
  interests         Json     @default("[]")
  skills_learned    Json     @default("[]")
  skills_to_learn   Json     @default("[]")
  planning_days     Int      @default(30)
  phone             String?  @db.VarChar(20)
  streak_snapshots  Json?    @default("[]")
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model DomainRoadmap {
  id               Int      @id @default(autoincrement())
  domain           String   @unique @db.VarChar(255)
  roadmap_content  Json
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("domain_roadmaps")
}

model Roadmap {
  id                  Int      @id @default(autoincrement())
  user_id             Int
  domain              String?  @db.VarChar(255)
  roadmap_content     Json?
  status              String   @default("active") @db.VarChar(20)
  progress_percentage Float    @default(0.0)
  completed_tasks     Json     @default("[]")
  completed_hours     Float?   @default(0)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_roadmaps")
}

model ChatHistory {
  id        Int      @id @default(autoincrement())
  user_id   Int
  sender    String   @db.VarChar(10) // 'user' or 'ai' (or 'bot')
  message   String   @db.Text
  engine    String?  @db.VarChar(50)
  timestamp DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("chat_history")
}

model Streak {
  user_id            Int      @id
  current_streak     Int      @default(0)
  last_activity_date DateTime? @db.Date
  updated_at         DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_learning_streak")
}

model Notification {
  id         Int      @id @default(autoincrement())
  user_id    Int
  type       String   @db.VarChar(50)
  title      String   @db.VarChar(255)
  message    String   @db.Text
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model CareerOnboardingState {
  id                Int      @id @default(autoincrement())
  uid               String   @unique @db.VarChar(100)
  step              String   @default("domain") @db.VarChar(30)
  domain            String?  @db.VarChar(255)
  proficiency_level String?  @db.VarChar(30)
  professional_goal String?  @db.VarChar(100)
  current_status    String?  @db.VarChar(50)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("career_onboarding_state")
}

model CareerEvent {
  id          Int      @id @default(autoincrement())
  type        String   @db.VarChar(30)
  title       String   @db.VarChar(255)
  description String?  @db.Text
  url         String?  @db.VarChar(500)
  domain      String?  @db.VarChar(255)
  level       String?  @db.VarChar(30)
  event_date  DateTime? @db.Timestamp
  created_at DateTime @default(now())

  @@map("career_events")
}

model PushSubscription {
  id         Int      @id @default(autoincrement())
  user_id    Int
  endpoint   String   @db.Text
  p256dh     String?  @db.Text
  auth       String?  @db.Text
  created_at DateTime @default(now())

  @@unique([user_id, endpoint])
  @@map("push_subscriptions")
}
